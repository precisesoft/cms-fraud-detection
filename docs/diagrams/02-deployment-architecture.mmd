%%{init: {'theme': 'base', 'themeVariables': {'primaryColor': '#e2e8f0', 'primaryTextColor': '#1e293b', 'primaryBorderColor': '#94a3b8', 'lineColor': '#64748b', 'secondaryColor': '#f1f5f9', 'tertiaryColor': '#f8fafc', 'fontFamily': 'Inter, system-ui, sans-serif'}}}%%

graph LR
    subgraph Dev["Developer Workstation"]
        CODE["Code Push<br/>to main"]
    end

    subgraph CI["GitHub Actions — CI"]
        direction TB
        LINT["Lint<br/><i>ruff + eslint</i>"]
        TEST["Test<br/><i>pytest + vitest</i>"]
        BUILD["Build Docker<br/>Images<br/><i>backend + frontend</i>"]
        PUSH["Push to<br/>Amazon ECR"]
        LINT --> TEST --> BUILD --> PUSH
    end

    subgraph CD["GitOps — ArgoCD"]
        ARGO["ArgoCD<br/><i>Detects manifest<br/>changes</i>"]
        SYNC["Auto Sync<br/><i>Kustomize overlays<br/>dev / prod</i>"]
        ARGO --> SYNC
    end

    subgraph EKS["Amazon EKS Cluster"]
        direction TB
        subgraph NS["Namespace: cms-fraud-detection"]
            FE_DEP["Frontend<br/><i>Next.js standalone<br/>2 replicas</i>"]
            BE_DEP["Backend<br/><i>FastAPI + Uvicorn<br/>2 replicas</i>"]
            PG_SS["PostgreSQL 16<br/><i>StatefulSet + PVC</i>"]
            NEO_SS["Neo4j 5<br/><i>StatefulSet + PVC</i>"]
        end
        ING["Ingress<br/><i>ALB / nginx</i>"]
        ING --> FE_DEP
        ING --> BE_DEP
        BE_DEP --> PG_SS
        BE_DEP --> NEO_SS
    end

    subgraph AWS["AWS Services"]
        ECR["Amazon ECR<br/><i>Container Registry</i>"]
        BEDROCK["AWS Bedrock<br/><i>Claude Sonnet</i>"]
    end

    CODE --> CI
    PUSH --> ECR
    ECR --> CD
    SYNC --> EKS
    BE_DEP --> BEDROCK
